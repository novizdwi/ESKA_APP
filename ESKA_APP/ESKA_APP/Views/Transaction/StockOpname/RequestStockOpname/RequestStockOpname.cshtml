    }



    function OnClickBtnListFind(s, e) {
        var popup = ASPxClientPopupControl.Cast("popupList");

        var gv = ASPxClientGridView.Cast('gvRequestStockOpnameList');
        if (gv == null) {
            popup.Show();
        } else {
            popup.SetContentHtml("");
            popup.PerformCallback();
            popup.Show();
        }
    }

    function OnClickBtnMenuOther(s, e) {

        switch (e.item.name) {

            case 'btnMenuSetStatusCancel':
                key = Id.GetValue();
                btnShowCancelReasonOnClick(s, e, key);

                break;
            case 'btnMenuSetStatusPost':
                if (BeforeSave() == false) {
                    return;
                }
                var formData = GetFormData();
                if (confirm('Post transaction?')) {
                    key = Id.GetValue();

                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("Post", "RequestStockOpname")',
                        data: formData,
                        beforeSend: function () {
                            OnBegin();
                        },
                        success: function (response) {
                            RefreshAfterSuccess(response);
                            OnSuccessMsgBox();

                        },
                        error: function (jqXhr, textStatus, errorThrown) {
                            OnFailure(jqXhr, textStatus, errorThrown)
                        },
                        complete: function () {
                            OnComplete()
                        }
                    });
                }


                break;
            default:

                break;
        }
    }

    function popupCancelReason_EndCallback(s, e) {
        $.validator.unobtrusive.parse("#CancelReason_formDetail");

        var popup = ASPxClientPopupControl.Cast("popupCancelReason");
        if (!popup.IsVisible()) {
            loadingPanel.Hide();
            popup.ShowAtPos(400, 100);
        }
    }

    function btnShowCancelReasonOnClick(s, e, Id) {
        var popup = ASPxClientPopupControl.Cast("popupCancelReason");

        popup.callbackUrl = '@Url.Action("CancelReason_PopupListOnDemandPartial", "RequestStockOpname")' + '?Id=' + Id;
        popup.PerformCallback();

        if (!popup.IsVisible()) {
            loadingPanel.Show();
        }
    }

    function btnUpdateReasonOnClick(s, e) {
        key = Id.GetValue();

        var reason = CancelReason2.GetValue();
        if (reason == "" || reason == null) {
            return;
        }

        $.ajax({
            type: "POST",
            url: '@Url.Action("Cancel", "RequestStockOpname")',
            data: { Id: key, CancelReason: reason },
            beforeSend: function () {
                OnBegin();
            },
            success: function (response) {
                popupCancelReason.Hide();
                RefreshAfterSuccess(response);
                OnSuccessMsgBox();
            },
            error: function (jqXhr, textStatus, errorThrown) {
                OnFailure(jqXhr, textStatus, errorThrown)
            },
            complete: function () {
                OnComplete()

            }
        });

    }

    function OnClickChoose(s, e, key) {
        $.ajax({
            type: "POST",
            url: '@Url.Action("DetailPartial", "RequestStockOpname")',
            data: { Id: key },
            beforeSend: function () {
                OnBegin();
            },
            success: function (response) {
                RefreshAfterSuccess(response);
                OnSuccess();
                popupList.Hide();
            },
            error: function (jqXhr, textStatus, errorThrown) {
                OnFailure(jqXhr, textStatus, errorThrown)
            },
            complete: function () {
                OnComplete()
            }
        });
    }

    function BtnCflWhsCodeOnClick(s, e) {
        cflWarehousePopupListRequestStockOpname.Show();
    }
</script>


