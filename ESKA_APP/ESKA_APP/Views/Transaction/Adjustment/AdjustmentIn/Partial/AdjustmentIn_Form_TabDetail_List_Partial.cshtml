@using Models;
@using Models._Cfl;
@{
    var Id = Convert.ToInt64(Request["cbId"]);

    if (ViewBag.Id != null)
    {
        Id = ViewBag.Id;
    }
    string status = Models._Ef.DbProvider.dbApp.Database.SqlQuery<string>("SELECT TOP 1 T0.\"Status\" FROM \"Tx_AdjustmentIn\" T0 WHERE T0.\"Id\"=:p0", Id).FirstOrDefault();
    ViewBag.ReadOnly = status == "Draft" ? false : true;

}

