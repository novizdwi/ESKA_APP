    -----------------------------------------------------------------------------
*@
<script>
    function btnBrowseTemplate_OnClick (s, e)
    {
        UploadMultiFile.Upload();
    }

    function gvTransferRequestTemplateUploadDetailBeginCallback(s, e) {
        e.customArgs['cbId'] = Id.GetValue();
    }


    function gvTransferRequestTemplateUploadDetail_OnClickBtnNew() {
        var popup = ASPxClientPopupControl.Cast("popupTemplateUpload");
        popup.callbackUrl = '@Url.Action("TemplateUpload_PopupListLoadOnDemandPartial", "TransferRequest")' + '?Id=' + Id.GetValue(); // "/ESKA_APP/TransferRequest/TemplateUpload_PopupListLoadOnDemandPartial?Id=" + Id.GetValue();

        popup.PerformCallback();


        popup.Show();
    }

    function TemplateUpload_OnClickBtnTemplateUpload(s, e) {
        // TemplateUpload_formDetail.action = '@Url.Action("TemplateUpload_TemplateUpload", "TransferRequest")';
        // $("#TemplateUpload_formDetail").submit();

        TemplateUploadMultiFile.TemplateUpload();

    }

    function TemplateUpload_OnClickBtnCancel(s, e) {
        var popup = ASPxClientPopupControl.Cast("popupTemplateUpload");
        popup.Hide();

    }

    function TemplateUpload_FileTemplateUploadComplete(s, e) {
        var popup = ASPxClientPopupControl.Cast("popupTemplateUpload");
        popup.Hide();
        gvTransferRequestTemplateUploadDetail.PerformCallback();;
    }

    function TemplateUpload_FileUploadComplete(s, e) {
        if (!e.isValid)
            return;

        try {
            var data = JSON.parse(e.callbackData);

            if (!data.success) {
                alert(data.message);
            } else {
                key = Id.GetValue();

                FileTemplateName_.SetValue(data.FileName);
                var popup = ASPxClientPopupControl.Cast("popupTemplateUpload");
                popup.Hide();
                var dateValue = new Date(data.Model.TransDate);

                TransDate.SetValue(dateValue);
                FromWhsCode.SetValue(data.Model.FromWhsCode);
                FromWhsName.SetValue(data.Model.FromWhsName);
                ToWhsCode.SetValue(data.Model.ToWhsCode);
                ToWhsName.SetValue(data.Model.ToWhsName);
                Comments.SetValue(data.Model.Comments);

                var grid = ASPxClientGridView.Cast("gvTransferRequestDetail");
                var details = data.Model.Detail_;
                //reset grid
                grid.CancelEdit();
                //var visibleRows = grid.GetVisibleRowsOnPage();
                //for (var i = visibleRows - 1; i >= 0; i--) {
                //    grid.batchEditApi.StartEdit(i, 0); // aktifkan row
                //    grid.batchEditApi.DeleteRow(i); // ini menambahkan key ke deletedRowKeys
                //}

                for (var i = 0; i < details.length; i++) {
                    grid.AddNewRow(); // mulai row baru

                    // Set value per column
                    grid.batchEditApi.SetCellValue(key, "Id", key);
                    grid.batchEditApi.SetCellValue(i, "DetId", details[i].DetId);
                    grid.batchEditApi.SetCellValue(i, "ItemCode", details[i].ItemCode);
                    grid.batchEditApi.SetCellValue(i, "ItemName", details[i].ItemName);
                    grid.batchEditApi.SetCellValue(i, "Quantity", details[i].Quantity);
                    grid.batchEditApi.SetCellValue(i, "QuantityOnHand_", details[i].QuantityOpen);
                    grid.batchEditApi.SetCellValue(i, "ToWhsCode", data.Model.ToWhsCode);
                    grid.batchEditApi.SetCellValue(i, "ToWhsName", data.Model.ToWhsName);
                    grid.batchEditApi.SetCellValue(i, "Comments", details[i].Comments);

                    gvTransferRequestDetail_ItemCode.SetValue(details[i].ItemCode);
                    gvTransferRequestDetail_ItemName.SetValue(details[i].ItemName);
                    gvTransferRequestDetail_Quantity.SetValue(details[i].Quantity);
                    gvTransferRequestDetail_QuantityOnHand_.SetValue(details[i].QuantityOpen);
                    gvTransferRequestDetail_ToWhsCode.SetValue(data.Model.ToWhsCode);
                    gvTransferRequestDetail_ToWhsName.SetValue(data.Model.ToWhsName);
                    gvTransferRequestDetail_Comments.SetValue(details[i].Comments);
                }

                //alert(data.message);
            }
        } catch (err) {
            alert(err);
        }



    }

function gvTransferRequestTemplateUploadDetail_OnClickBtnDelete(DetId) {
    //if (Status.GetValue() == "Posted" )
    //{
    //    alert("Tidak dapat di delete jika sudah posted!");
    //    return;
    //}

    if (confirm('Delete data?')) {
        var gv = ASPxClientGridView.Cast("gvTransferRequestTemplateUploadDetail");
        gv.DeleteRowByKey(DetId);
    }
}
</script>
