<script type="text/javascript">

    function BtnCflItemByWarehousePopupListTransferRequestOnClick(s, e) {

        var popup = ASPxClientPopupControl.Cast("cflItemByWarehousePopupListTransferRequest");

        var gv = ASPxClientGridView.Cast('gvCflItemByWarehouseListTransferRequest');

        if (gv == null) {
            popup.Show();
        } else {
            popup.SetContentHtml("");
            popup.PerformCallback();
            popup.Show();
        }
    }


    function OnClickChoose_CflItemByWarehouseTransferRequest(s, e) {
        gvCflItemByWarehouseListTransferRequest.GetSelectedFieldValues('ItemCode', GetSelectedFieldValuesCallback_CflItemByWarehouse);
    }


    function GetSelectedFieldValuesCallback_CflItemByWarehouse(values) {
        cflItemByWarehousePopupListTransferRequest.Hide();

        key = Id.GetValue();
        fromWhsCodeKey = FromWhsCode.GetValue();

        $.ajax({
            type: "POST",
            url: '@Url.Action("ChooseItem", "TransferRequest")',
            data: { Id: key, Data: values },
            beforeSend: function () {
                OnBegin();
            },
            success: function (response) {
                gvTransferRequestDetail.PerformCallback();
                OnSuccessMsgBox();
            },
            error: function (jqXhr, textStatus, errorThrown) {
                OnFailure(jqXhr, textStatus, errorThrown)
            },
            complete: function () {
                OnComplete();
            }
        });

    }

</script>
@Html.Partial("~/Views/_Cfl/_CflItemByWarehouse/Partial/_CflItemByWarehouse_Panel_List_Partial.cshtml", cflItemByWarehouse_ParamModel)


