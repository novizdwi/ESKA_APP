    function OnClickBtnMenuOther(s, e) {

        switch (e.item.name) {
            case 'btnMenuAuthorize':
                key = Id.GetValue();
                btnShowApprovalOnClick(s, e, key);
                break;
            case 'btnMenuSetStatusCancel':
                key = Id.GetValue();
                btnShowCancelReasonOnClick(s, e, key);

                break;
            case 'btnMenuSetStatusPost':
                if (BeforeSave() == false) {
                    return;
                }
                var formData = GetFormData();
                if (confirm('Post transaction?')) {
                    key = Id.GetValue();

                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("Post", "TransferRequest")',
                        data: formData,
                        beforeSend: function () {
                            OnBegin();
                        },
                        success: function (response) {
                            RefreshAfterSuccess(response);
                            OnSuccessMsgBox();

                        },
                        error: function (jqXhr, textStatus, errorThrown) {
                            OnFailure(jqXhr, textStatus, errorThrown)
                        },
                        complete: function () {
                            OnComplete()
                        }
                    });
                }


                break;
            case 'btnMenuTemplateUpload':
                var popup = ASPxClientPopupControl.Cast("popupTemplateUpload");
                popup.callbackUrl = '@Url.Action("TemplateUpload_PopupListLoadOnDemandPartial", "TransferRequest")' + '?Id=' + Id.GetValue();
                popup.PerformCallback();
                popup.Show();

                break;
            case 'btnMenuSetBtnTemplateDownload':
                var key = Id.GetValue();
                var url = '@Url.Action("TemplateDownload", "TransferRequest")' + '?Id=' + key;
                window.location.href = url;
                break;
            default:

                break;
        }
    }

