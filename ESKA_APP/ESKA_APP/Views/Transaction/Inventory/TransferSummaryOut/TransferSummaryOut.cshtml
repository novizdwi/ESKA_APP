    function OnClickBtnMenuOther(s, e) {

        switch (e.item.name) {
            case 'btnMenuAuthorize':
                key = Id.GetValue();
                btnShowApprovalOnClick(s, e, key);
                break;
            case 'btnMenuSetStatusCancel':
                key = Id.GetValue();
